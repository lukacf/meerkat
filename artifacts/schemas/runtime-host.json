          "mobs": {
            "type": "boolean"
          },
          "runtime_backed_sessions": {
            "type": "boolean"
          },
          "schedules": {
            "type": "boolean"
          },
          "secure_remote_rpc": {
            "type": "boolean"
          },
          "session_events": {
            "type": "boolean"
          },
          "session_streams": {
            "type": "boolean"
          },
          "skills": {
            "type": "boolean"
          }
