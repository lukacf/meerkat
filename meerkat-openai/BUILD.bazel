load("@crates//:defs.bzl", "aliases", "all_crate_deps")

load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_proc_macro", "rust_test")



filegroup(

    name = "cargo_manifest",

    srcs = ["Cargo.toml"],

    visibility = ["//visibility:public"],

)



filegroup(

    name = "package_runfiles",

    srcs = glob(["Cargo.toml", "**/*"], exclude = ["BUILD", "BUILD.bazel"], allow_empty = True),

    visibility = ["//visibility:public"],

)



rust_library(
    name = "meerkat_openai",
    aliases = aliases(package_name = "meerkat-openai"),
    crate_name = "meerkat_openai",
    crate_root = "src/lib.rs",
    crate_features = [
        "oauth",
        "realtime",
    ],
    edition = "2024",
    compile_data = [
        "Cargo.toml",
    ],
    srcs = glob(["src/**/*.rs"]),
    visibility = ["//visibility:public"],
    rustc_env = {
        "CARGO_PKG_VERSION": "0.6.4",
        "CARGO_MANIFEST_DIR": "./meerkat-openai",
    },
    proc_macro_deps = all_crate_deps(
        package_name = "meerkat-openai",
        proc_macro = True,
    ),
    deps = [
        "//meerkat-auth-core:meerkat_auth_core",
        "//meerkat-contracts:meerkat_contracts",
        "//meerkat-core:meerkat_core",
        "//meerkat-llm-core:meerkat_llm_core",
        "//meerkat-runtime:meerkat_runtime",
    ] + all_crate_deps(
        package_name = "meerkat-openai",
        normal = True,
    ),
)

