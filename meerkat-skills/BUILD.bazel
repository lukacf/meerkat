load("@crates//:defs.bzl", "aliases", "all_crate_deps")

load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_proc_macro", "rust_test")



filegroup(

    name = "cargo_manifest",

    srcs = ["Cargo.toml"],

    visibility = ["//visibility:public"],

)



filegroup(

    name = "package_runfiles",

    srcs = glob(["Cargo.toml", "**/*"], exclude = ["BUILD", "BUILD.bazel"], allow_empty = True),

    visibility = ["//visibility:public"],

)



rust_library(
    name = "meerkat_skills",
    aliases = aliases(package_name = "meerkat-skills"),
    crate_name = "meerkat_skills",
    crate_root = "src/lib.rs",
    crate_features = [
        "capability",
        "skills-http",
    ],
    edition = "2024",
    compile_data = [
        "Cargo.toml",
    ],
    srcs = glob(["src/**/*.rs"]),
    visibility = ["//visibility:public"],
    rustc_env = {
        "CARGO_PKG_VERSION": "0.6.21",
        "CARGO_MANIFEST_DIR": "./meerkat-skills",
    },
    proc_macro_deps = all_crate_deps(
        package_name = "meerkat-skills",
        proc_macro = True,
    ),
    deps = [
        "//meerkat-capabilities:meerkat_capabilities",
        "//meerkat-core:meerkat_core",
    ] + all_crate_deps(
        package_name = "meerkat-skills",
        normal = True,
    ),
)

rust_library(
    name = "meerkat_skills_agent_factory_build",
    aliases = aliases(package_name = "meerkat-skills"),
    crate_name = "meerkat_skills",
    crate_root = "src/lib.rs",
