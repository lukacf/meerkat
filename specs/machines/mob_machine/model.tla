SpawnRunningFresh(agent_identity, agent_runtime_id, fence_token, generation, profile_material_digest, external_addressable, runtime_mode, bridge_session_id, replacing) ==
    /\ phase = "Running"
    /\ (coordinator_bound = TRUE)
    /\ ((agent_identity \in DOMAIN member_session_bindings) = FALSE)
    /\ (replacing = None)
    /\ mob_machine_external_peer_identity_absent(external_peer_edges, agent_identity)
    /\ ((agent_identity \in DOMAIN spawn_profile_authority_profile_names) = TRUE)
    /\ ((IF (agent_identity \in DOMAIN spawn_profile_authority_material_digests) THEN Some((IF agent_identity \in DOMAIN spawn_profile_authority_material_digests THEN spawn_profile_authority_material_digests[agent_identity] ELSE "None")) ELSE None) = Some(profile_material_digest))
    /\ ((IF (agent_identity \in DOMAIN spawn_profile_authority_external_addressable) THEN Some((IF agent_identity \in DOMAIN spawn_profile_authority_external_addressable THEN spawn_profile_authority_external_addressable[agent_identity] ELSE FALSE)) ELSE None) = Some(external_addressable))
    /\ (bridge_session_id # None)
    /\ phase' = "Running"
    /\ model_step_count' = model_step_count + 1
    /\ live_runtime_ids' = (live_runtime_ids \cup {agent_runtime_id})
    /\ externally_addressable_runtime_ids' = IF external_addressable THEN (externally_addressable_runtime_ids \cup {agent_runtime_id}) ELSE (externally_addressable_runtime_ids \ {agent_runtime_id})
    /\ runtime_fence_tokens' = MapSet(runtime_fence_tokens, agent_runtime_id, fence_token)
    /\ identity_runtime_generations' = MapSet(identity_runtime_generations, agent_identity, generation)
    /\ identity_runtime_fence_tokens' = MapSet(identity_runtime_fence_tokens, agent_identity, fence_token)
    /\ member_startup_binding_requested' = (member_startup_binding_requested \cup {agent_runtime_id})
    /\ member_startup_runtime_ready' = (member_startup_runtime_ready \ {agent_runtime_id})
    /\ member_startup_ready' = (member_startup_ready \ {agent_runtime_id})
    /\ member_restore_failures' = MapRemove(member_restore_failures, agent_identity)
    /\ identity_to_runtime' = MapSet(identity_to_runtime, agent_identity, agent_runtime_id)
    /\ member_session_bindings' = MapSet(member_session_bindings, agent_identity, (IF "value" \in DOMAIN bridge_session_id THEN bridge_session_id["value"] ELSE None))
    /\ member_profile_names' = MapSet(member_profile_names, agent_identity, (IF "value" \in DOMAIN (IF (agent_identity \in DOMAIN spawn_profile_authority_profile_names) THEN Some((IF agent_identity \in DOMAIN spawn_profile_authority_profile_names THEN spawn_profile_authority_profile_names[agent_identity] ELSE "None")) ELSE None) THEN (IF (agent_identity \in DOMAIN spawn_profile_authority_profile_names) THEN Some((IF agent_identity \in DOMAIN spawn_profile_authority_profile_names THEN spawn_profile_authority_profile_names[agent_identity] ELSE "None")) ELSE None)["value"] ELSE None))
    /\ member_runtime_modes' = MapSet(member_runtime_modes, agent_identity, runtime_mode)
    /\ spawn_profile_authority_profile_names' = MapRemove(spawn_profile_authority_profile_names, agent_identity)
    /\ spawn_profile_authority_models' = MapRemove(spawn_profile_authority_models, agent_identity)
    /\ spawn_profile_authority_material_digests' = MapRemove(spawn_profile_authority_material_digests, agent_identity)
    /\ spawn_profile_authority_tool_config_digests' = MapRemove(spawn_profile_authority_tool_config_digests, agent_identity)
    /\ spawn_profile_authority_skills_digests' = MapRemove(spawn_profile_authority_skills_digests, agent_identity)
    /\ spawn_profile_authority_provider_params_digests' = MapRemove(spawn_profile_authority_provider_params_digests, agent_identity)
    /\ spawn_profile_authority_output_schema_digests' = MapRemove(spawn_profile_authority_output_schema_digests, agent_identity)
    /\ spawn_profile_authority_external_addressable' = MapRemove(spawn_profile_authority_external_addressable, agent_identity)
