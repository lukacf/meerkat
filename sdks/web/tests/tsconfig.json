{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "baseUrl": ".."
  },
  "include": ["./**/*.ts", "../src/**/*.ts"]
}
