load("@crates//:defs.bzl", "aliases", "all_crate_deps")

load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_proc_macro", "rust_test")



filegroup(

    name = "cargo_manifest",

    srcs = ["Cargo.toml"],

    visibility = ["//visibility:public"],

)



filegroup(

    name = "package_runfiles",

    srcs = glob(["Cargo.toml", "**/*"], exclude = ["BUILD", "BUILD.bazel"], allow_empty = True),

    visibility = ["//visibility:public"],

)



rust_binary(
    name = "embedded_min_bin",
    aliases = aliases(package_name = "test-fixtures/surface-build-fixtures"),
    crate_name = "embedded_min",
    crate_root = "src/bin/embedded_min.rs",
    crate_features = [],
    edition = "2024",
    compile_data = [
        "Cargo.toml",
    ],
    srcs = glob(["src/**/*.rs"]),
    visibility = ["//visibility:public"],
    rustc_env = {
        "CARGO_PKG_VERSION": "0.6.19",
        "CARGO_BIN_NAME": "embedded_min",
        "CARGO_MANIFEST_DIR": "test-fixtures/surface-build-fixtures",
    },
    proc_macro_deps = all_crate_deps(
        package_name = "test-fixtures/surface-build-fixtures",
        proc_macro = True,
    ),
    deps = [
        "//meerkat:meerkat",
    ] + all_crate_deps(
        package_name = "test-fixtures/surface-build-fixtures",
        normal = True,
    ),
)

rust_binary(
    name = "runtime_backed_min_bin",
    aliases = aliases(package_name = "test-fixtures/surface-build-fixtures"),
    crate_name = "runtime_backed_min",
    crate_root = "src/bin/runtime_backed_min.rs",
    crate_features = [],
    edition = "2024",
    compile_data = [
        "Cargo.toml",
    ],
    srcs = glob(["src/**/*.rs"]),
    visibility = ["//visibility:public"],
    rustc_env = {
        "CARGO_PKG_VERSION": "0.6.19",
        "CARGO_BIN_NAME": "runtime_backed_min",
        "CARGO_MANIFEST_DIR": "test-fixtures/surface-build-fixtures",
    },
    proc_macro_deps = all_crate_deps(
        package_name = "test-fixtures/surface-build-fixtures",
        proc_macro = True,
    ),
    deps = [
        "//meerkat:meerkat",
    ] + all_crate_deps(
        package_name = "test-fixtures/surface-build-fixtures",
        normal = True,
    ),
)

rust_test(
    name = "live_roundtrip_test",
    aliases = aliases(
        package_name = "test-fixtures/surface-build-fixtures",
        normal = True,
        normal_dev = True,
        proc_macro = True,
        proc_macro_dev = True,
    ),
    crate_name = "live_roundtrip",
    crate_root = "tests/live_roundtrip.rs",
    crate_features = [],
    edition = "2024",
    compile_data = [
        "Cargo.toml",
    ],
    srcs = [
        "tests/live_roundtrip.rs",
    ],
    visibility = ["//visibility:public"],
    rustc_env = {
        "CARGO_PKG_VERSION": "0.6.19",
        "CARGO_BIN_NAME": "live_roundtrip",
        "CARGO_MANIFEST_DIR": "./test-fixtures/surface-build-fixtures",
    },
    tags = [
        "fixture",
        "live",
    ],
    data = [],
    env = {
        "RUST_MIN_STACK": "16777216",
    },
    proc_macro_deps = all_crate_deps(
        package_name = "test-fixtures/surface-build-fixtures",
        proc_macro = True,
        proc_macro_dev = True,
