RouteDeliveryKind(route_name) ==
    CASE route_name = "work_item_close_stops_attention" -> "Immediate"
      [] OTHER -> "Unknown"

RouteTargetActor(route_name) == ActorOfMachine(RouteTargetMachine(route_name))

