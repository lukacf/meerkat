  "MobUnwireParams": {
    "$defs": {
      "MobPeerTarget": {
        "description": "Target for a mob wire/unwire call.",
        "oneOf": [
          {
            "additionalProperties": false,
            "properties": {
              "local": {
                "type": "string"
              }
            },
            "required": [
              "local"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "external": {
                "$ref": "#/$defs/WireTrustedPeerSpec"
              }
            },
            "required": [
              "external"
            ],
            "type": "object"
          }
        ]
      },
      "WireTrustedPeerSpec": {
        "description": "Minimal trusted peer spec for public mob wiring surfaces.",
        "properties": {
          "address": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "peer_id": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "peer_id",
          "address"
        ],
        "type": "object"
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Request payload for `mob/unwire`.",
    "properties": {
      "local": {
        "type": "string"
      },
      "mob_id": {
        "type": "string"
      },
      "target": {
        "$ref": "#/$defs/MobPeerTarget"
      }
    },
    "required": [
      "mob_id",
      "local",
      "target"
    ],
    "title": "MobUnwireParams",
    "type": "object"
  },
