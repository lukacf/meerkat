#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_cargo="${script_dir}/repo-cargo"

exec "${repo_cargo}" nextest run \
  --workspace \
  -E 'not binary(e2e_auth_lane) and not binary(e2e_build_lane) and not binary(e2e_fast_lane) and not binary(e2e_system_lane) and not binary(e2e_live_lane) and not binary(e2e_smoke_lane) and not binary(e2e_models_lane)' \
  --show-progress none \
  --status-level none \
  --final-status-level fail \
  "$@"
