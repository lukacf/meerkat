                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "args"
            ],
            "type": "object"
          }
        },
        "required": [
          "block_type",
          "data"
        ],
        "type": "object"
      },
      {
        "properties": {
          "block_type": {
            "const": "unknown",
            "type": "string"
          }
        },
        "required": [
          "block_type"
        ],
        "type": "object"
      }
