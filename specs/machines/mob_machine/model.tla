    /\ phase = "Running"
    /\ (coordinator_bound = TRUE)
    /\ ((agent_identity \in DOMAIN member_session_bindings) = TRUE)
    /\ (replacing # None)
    /\ ((IF (agent_identity \in DOMAIN member_session_bindings) THEN Some((IF agent_identity \in DOMAIN member_session_bindings THEN member_session_bindings[agent_identity] ELSE "None")) ELSE None) = Some((IF "value" \in DOMAIN replacing THEN replacing["value"] ELSE None)))
    /\ mob_machine_external_peer_identity_absent(external_peer_edges, agent_identity)
    /\ ((agent_identity \in DOMAIN spawn_profile_authority_profile_names) = TRUE)
    /\ ((IF (agent_identity \in DOMAIN spawn_profile_authority_material_digests) THEN Some((IF agent_identity \in DOMAIN spawn_profile_authority_material_digests THEN spawn_profile_authority_material_digests[agent_identity] ELSE "None")) ELSE None) = Some(profile_material_digest))
    /\ ((IF (agent_identity \in DOMAIN spawn_profile_authority_external_addressable) THEN Some((IF agent_identity \in DOMAIN spawn_profile_authority_external_addressable THEN spawn_profile_authority_external_addressable[agent_identity] ELSE FALSE)) ELSE None) = Some(external_addressable))
    /\ (bridge_session_id # None)
    /\ phase' = "Running"
    /\ model_step_count' = model_step_count + 1
    /\ live_runtime_ids' = (live_runtime_ids \cup {agent_runtime_id})
    /\ externally_addressable_runtime_ids' = IF external_addressable THEN (externally_addressable_runtime_ids \cup {agent_runtime_id}) ELSE (externally_addressable_runtime_ids \ {agent_runtime_id})
    /\ runtime_fence_tokens' = MapSet(runtime_fence_tokens, agent_runtime_id, fence_token)
    /\ identity_runtime_generations' = MapSet(identity_runtime_generations, agent_identity, generation)
