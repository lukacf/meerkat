        "type": "object"
      },
      "CapabilityId": {
        "description": "Every capability known to Meerkat. Adding a variant forces updates to\nthe registry, error mappings, and codegen templates.",
        "oneOf": [
          {
            "enum": [
              "sessions",
              "streaming",
              "structured_output",
              "hooks",
              "builtins",
              "shell",
              "comms",
              "memory_store",
              "schedule",
              "work_graph",
              "session_store",
              "session_compaction",
              "skills",
              "mcp_live"
            ],
            "type": "string"
          },
          {
            "const": "adaptive_flow",
            "description": "Adaptive mobpack flow execution (FlowMaster planning loop, layer\ncompilation, policy composition). Stamped into a mobpack's\n`[requires]` section by the pack builder whenever the manifest\ndeclares an `[adaptive]` section, so hosts that do not know this\ncapability fail closed instead of silently downgrading the pack.",
            "type": "string"
          }
        ]
      },
      "ErrorCategory": {
        "description": "Error category for grouping.",
        "enum": [
          "session",
          "request",
          "provider",
          "budget",
          "hook",
          "agent",
          "capability",
          "skill",
          "validation",
          "internal"
        ],
        "type": "string"
      },
      "ErrorCode": {
        "description": "Stable error codes for wire protocol.",
        "oneOf": [
          {
            "enum": [
              "SESSION_NOT_FOUND",
              "SCHEDULE_NOT_FOUND",
              "SESSION_BUSY",
              "SESSION_NOT_RUNNING",
              "REQUEST_CANCELLED",
              "PROVIDER_ERROR",
              "BUDGET_EXHAUSTED",
              "HOOK_DENIED",
              "AGENT_ERROR",
              "CAPABILITY_UNAVAILABLE",
              "SKILL_NOT_FOUND",
              "SKILL_RESOLUTION_FAILED",
              "INVALID_PARAMS",
              "INTERNAL_ERROR",
              "DUPLICATE_INPUT",
              "SUPERVISOR_ROTATION_INCOMPLETE"
            ],
            "type": "string"
          },
          {
            "const": "SCOPE_DENIED",
            "description": "Plane-(b) control-scope denial; wire detail carries\n`{ required, presented }`.",
            "type": "string"
          },
          {
            "const": "HOST_UNAVAILABLE",
            "description": "Member host unreachable/timeout; observation degrades typed, never\nquiet.",
            "type": "string"
          },
          {
            "const": "STALE_CURSOR",
            "description": "Event cursor overran an ephemeral host's buffer; reply carries the\ncurrent watermark.",
            "type": "string"
          },
          {
            "const": "STALE_FENCE",
