RecoverInputLifecycleIdle(input_id, arg_phase, terminal_kind, superseded_by, aggregate_id, abandon_reason, abandon_attempt_count, attempt_count, run_id, boundary_sequence, lane) ==
    /\ phase = "Idle"
    /\ phase' = "Idle"
    /\ model_step_count' = model_step_count + 1
    /\ input_phases' = MapSet(input_phases, input_id, arg_phase)
    /\ input_terminal_kind' = IF (terminal_kind # None) THEN MapSet(input_terminal_kind, input_id, (IF "value" \in DOMAIN terminal_kind THEN terminal_kind["value"] ELSE None)) ELSE MapRemove(input_terminal_kind, input_id)
    /\ input_superseded_by' = IF (superseded_by # None) THEN MapSet(input_superseded_by, input_id, (IF "value" \in DOMAIN superseded_by THEN superseded_by["value"] ELSE None)) ELSE MapRemove(input_superseded_by, input_id)
    /\ input_aggregate_id' = IF (aggregate_id # None) THEN MapSet(input_aggregate_id, input_id, (IF "value" \in DOMAIN aggregate_id THEN aggregate_id["value"] ELSE None)) ELSE MapRemove(input_aggregate_id, input_id)
    /\ input_abandon_reason' = IF (abandon_reason # None) THEN MapSet(input_abandon_reason, input_id, (IF "value" \in DOMAIN abandon_reason THEN abandon_reason["value"] ELSE None)) ELSE MapRemove(input_abandon_reason, input_id)
    /\ input_abandon_attempt_count' = IF (abandon_reason # None) THEN MapSet(input_abandon_attempt_count, input_id, abandon_attempt_count) ELSE MapRemove(input_abandon_attempt_count, input_id)
    /\ input_attempt_counts' = MapSet(input_attempt_counts, input_id, attempt_count)
    /\ input_run_associations' = IF (run_id # None) THEN MapSet(input_run_associations, input_id, (IF "value" \in DOMAIN run_id THEN run_id["value"] ELSE None)) ELSE MapRemove(input_run_associations, input_id)
    /\ input_boundary_sequences' = IF (boundary_sequence # None) THEN MapSet(input_boundary_sequences, input_id, (IF "value" \in DOMAIN boundary_sequence THEN boundary_sequence["value"] ELSE None)) ELSE MapRemove(input_boundary_sequences, input_id)
    /\ next_admission_seq' = IF ~((input_id \in DOMAIN input_admission_seq)) THEN (next_admission_seq) + 1 ELSE next_admission_seq
