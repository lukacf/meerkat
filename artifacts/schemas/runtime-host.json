          "runtime_backed_sessions",
          "mobs",
          "mcp_live",
          "comms",
          "blobs",
          "session_events",
          "session_streams",
          "schedules",
          "skills",
          "event_replay",
          "artifacts",
          "approvals",
          "external_members",
          "secure_remote_rpc"
        ],
        "type": "object"
      }
