# MDM Target configuration — runs on the managed machine.
#
# 1. Start the target:
#      ANTHROPIC_API_KEY=... cargo run --bin target -- target.toml.example
# 2. Copy the printed pubkey into tux.toml [[targets]]
# 3. Start TUX on the controller machine.

name        = "mac-laptop"
listen_addr = "0.0.0.0:4748"
model       = "claude-sonnet-4-6"
data_dir    = ".target-data"

# Add TUX's pubkey here (printed when TUX starts).
[[trusted_peers]]
name   = "tux"
pubkey = "ed25519:REPLACE_WITH_TUX_PUBKEY"
addr   = "tcp://192.168.1.50:4747"
