load("@crates//:defs.bzl", "aliases", "all_crate_deps")

load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_proc_macro", "rust_test")



filegroup(

    name = "cargo_manifest",

    srcs = ["Cargo.toml"],

    visibility = ["//visibility:public"],

)



filegroup(

    name = "package_runfiles",

    srcs = glob(["Cargo.toml", "**/*"], exclude = ["BUILD", "BUILD.bazel"], allow_empty = True),

    visibility = ["//visibility:public"],

)



rust_binary(
    name = "mcp_test_server",
    aliases = aliases(package_name = "test-fixtures/mcp-test-server"),
    crate_name = "mcp_test_server",
    crate_root = "src/main.rs",
    crate_features = [],
    edition = "2024",
    compile_data = [
        "Cargo.toml",
    ],
    srcs = glob(["src/**/*.rs"]),
    visibility = ["//visibility:public"],
    rustc_env = {
        "CARGO_PKG_VERSION": "0.6.21",
        "CARGO_BIN_NAME": "mcp-test-server",
        "CARGO_MANIFEST_DIR": "test-fixtures/mcp-test-server",
    },
    proc_macro_deps = all_crate_deps(
        package_name = "test-fixtures/mcp-test-server",
        proc_macro = True,
    ),
    deps = all_crate_deps(
        package_name = "test-fixtures/mcp-test-server",
        normal = True,
    ),
)
