{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "baseUrl": ".."
  },
  "include": ["./**/*.ts", "../src/**/*.ts"]
}
