fence_requires_bound_runtime == ((active_fence_token = None) \/ (active_runtime_id # None))
running_has_current_run == ((phase # "Running") \/ (current_run_id # None))
current_run_only_while_running_or_retired == ((current_run_id = None) \/ (phase = "Running") \/ (phase = "Retired"))
staged_surface_ops_are_known_and_sequenced == (\A surface_id \in DOMAIN surface_staged_op : ((surface_id \in known_surfaces) /\ (surface_id \in DOMAIN surface_staged_intent_sequence)))
staged_reload_surfaces_are_active == (\A surface_id \in reload_staged_surfaces : (surface_id \in active_surfaces))
