load("@crates//:defs.bzl", "aliases", "all_crate_deps")

load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_proc_macro", "rust_test")



filegroup(

    name = "cargo_manifest",

    srcs = ["Cargo.toml"],

    visibility = ["//visibility:public"],

)



filegroup(

    name = "package_runfiles",

    srcs = glob(["Cargo.toml", "**/*"], exclude = ["BUILD", "BUILD.bazel"], allow_empty = True),

    visibility = ["//visibility:public"],

)



rust_library(
    name = "meerkat_tools",
    aliases = aliases(package_name = "meerkat-tools"),
    crate_name = "meerkat_tools",
    crate_root = "src/lib.rs",
    crate_features = [
        "comms",
        "mcp",
        "skills",
        "sqlite",
    ],
    edition = "2024",
    compile_data = [
        "Cargo.toml",
        "skills/builtin-utilities-workflow/SKILL.md",
        "skills/shell-patterns/SKILL.md",
        "skills/skill-discovery-workflow/SKILL.md",
        "skills/task-workflow/SKILL.md",
    ],
    srcs = glob(["src/**/*.rs"]),
    visibility = ["//visibility:public"],
    rustc_env = {
        "CARGO_PKG_VERSION": "0.6.19",
        "CARGO_MANIFEST_DIR": "./meerkat-tools",
    },
    proc_macro_deps = all_crate_deps(
        package_name = "meerkat-tools",
        proc_macro = True,
    ),
    deps = [
        "//meerkat-capabilities:meerkat_capabilities",
        "//meerkat-comms:meerkat_comms",
        "//meerkat-contracts:meerkat_contracts",
        "//meerkat-core:meerkat_core",
        "//meerkat-llm-core:meerkat_llm_core",
        "//meerkat-mcp:meerkat_mcp",
        "//meerkat-runtime:meerkat_runtime",
        "//meerkat-skills:meerkat_skills",
    ] + all_crate_deps(
        package_name = "meerkat-tools",
        normal = True,
    ),
)

