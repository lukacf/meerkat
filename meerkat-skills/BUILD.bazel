        "//meerkat:__pkg__",
    ],
    rustc_env = {
        "CARGO_PKG_VERSION": "0.6.21",
        "CARGO_MANIFEST_DIR": "./meerkat-skills",
    },
    proc_macro_deps = all_crate_deps(
        package_name = "meerkat-skills",
        proc_macro = True,
    ),
    deps = [
        "//meerkat:meerkat_capabilities_agent_factory_build",
        "//meerkat:meerkat_core_agent_factory_build",
    ] + all_crate_deps(
        package_name = "meerkat-skills",
        normal = True,
    ),
)

