impl FlowFrameLoopDecision {
    fn plan(plan: FlowFrameLoopStorePlan) -> Self {
        Self {
            store_plan: Some(plan),
            follow_up: Vec::new(),
        }
    }

    fn with_work(mut self, work: FlowFrameLoopWork) -> Self {
        self.follow_up.push(work);
        self
